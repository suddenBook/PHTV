<?xml version="1.0" encoding="utf-8"?>
<!--
  PlayerView backed by a TextureView (not the default SurfaceView). TextureView re-applies the video
  transform matrix every frame, so portrait videos can't get "stuck" stretched on a stale surface size
  (the transient glitch that a pause/resume used to clear). surface_type is only settable via XML, hence
  this layout. Behaviour (controller/focus) is configured programmatically in PlayerScreen.
-->
<androidx.media3.ui.PlayerView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:surface_type="texture_view"
    app:resize_mode="fit"
    app:use_controller="true"
    app:auto_show="false" />
